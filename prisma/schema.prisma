generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AnimeSource {
  ANILIST
  MANUAL
}

enum AiringStatus {
  FINISHED
  RELEASING
  HIATUS
  CANCELLED
  NOT_YET_RELEASED
}

enum DisplayFormat {
  SERIES
  MOVIE
}

enum SourceMaterial {
  ORIGINAL
  MANGA
  LIGHT_NOVEL
  NOVEL
  VISUAL_NOVEL
  VIDEO_GAME
  OTHER
}

enum Season {
  WINTER
  SPRING
  SUMMER
  FALL
}

enum FranchiseEntryType {
  MAIN
  SIDE_STORY
  MOVIE
  OVA
}

enum WatchStatus {
  WATCHING
  COMPLETED
  ON_HOLD
  DROPPED
  PLAN_TO_WATCH
  RECOMMENDED
  NOT_INTERESTED
}

enum StreamingService {
  NETFLIX
  HULU
  DISNEY_PLUS
  HBO
  CRUNCHYROLL
  AMAZON_PRIME
  HIDIVE
}

// ── Auth.js required models ──────────────────────────────────────────────────

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  userEntries   UserEntry[]
  franchises    Franchise[]
  people        Person[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── App models ───────────────────────────────────────────────────────────────

model Person {
  id                  Int         @id @default(autoincrement())
  name                String
  userId              String
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries             UserEntry[] @relation("Recommender")
  watchContextEntries UserEntry[] @relation("WatchContextPerson")
  createdAt           DateTime    @default(now())

  @@unique([name, userId])
}

model Franchise {
  id          Int              @id @default(autoincrement())
  name        String
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String?
  entries     FranchiseEntry[]
  createdAt   DateTime         @default(now())

  @@unique([name, userId])
}

model FranchiseEntry {
  id          Int                @id @default(autoincrement())
  franchise   Franchise          @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  franchiseId Int
  anime       Anime              @relation(fields: [animeId], references: [id], onDelete: Cascade)
  animeId     Int
  order       Int
  entryType   FranchiseEntryType @default(MAIN)

  @@unique([franchiseId, animeId])
  @@unique([franchiseId, order])
}

model Studio {
  id              Int           @id @default(autoincrement())
  name            String        @unique
  anilistStudioId Int?          @unique
  animeStudios    AnimeStudio[]
}

model AnimeStudio {
  anime        Anime   @relation(fields: [animeId], references: [id], onDelete: Cascade)
  animeId      Int
  studio       Studio  @relation(fields: [studioId], references: [id])
  studioId     Int
  isMainStudio Boolean @default(false)

  @@id([animeId, studioId])
}

model Anime {
  id             Int            @id @default(autoincrement())
  anilistId      Int?           @unique
  source         AnimeSource    @default(ANILIST)
  titleEnglish   String?
  titleRomaji    String
  titleNative    String?
  coverImageUrl  String?
  synopsis       String?
  genres         String         @default("[]") // stored as JSON array string
  totalEpisodes     Int?
  totalSeasons      Int?
  episodesPerSeason String? // JSON array e.g. [13,10,13,14,12]
  durationMins   Int?
  airingStatus   AiringStatus   @default(FINISHED)
  displayFormat  DisplayFormat  @default(SERIES)
  sourceMaterial SourceMaterial?
  season         Season?
  seasonYear     Int?
  meanScore      Int?           // AniList community score 0-100
  nextAiringEp   Int?           // next episode number (RELEASING shows)
  nextAiringAt   DateTime?      // timestamp of next episode
  lastSyncedAt       DateTime?
  tmdbId             Int?
  tmdbMediaType      String?     // "tv" or "movie"
  externalUrl        String?     // custom link for manually-added anime (e.g. TMDB)
  streamingCheckedAt DateTime?
  createdAt          DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  mergedIntoId     Int?
  mergedInto       Anime?           @relation("AnimeMerge", fields: [mergedIntoId], references: [id])
  mergedAnimes     Anime[]          @relation("AnimeMerge")

  franchiseEntries FranchiseEntry[]
  animeStudios     AnimeStudio[]
  userEntries      UserEntry[]
  streamingLinks   StreamingLink[]
}

model StreamingLink {
  id      Int              @id @default(autoincrement())
  anime   Anime            @relation(fields: [animeId], references: [id], onDelete: Cascade)
  animeId Int
  service StreamingService
  url     String

  @@unique([animeId, service])
}

model UserEntry {
  id             Int          @id @default(autoincrement())
  anime          Anime        @relation(fields: [animeId], references: [id], onDelete: Cascade)
  animeId        Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  watchStatus    WatchStatus  @default(PLAN_TO_WATCH)
  currentEpisode Int          @default(0)
  score          Float?       // 1-10, user's personal rating
  notes          String?
  watchContextPerson   Person?      @relation("WatchContextPerson", fields: [watchContextPersonId], references: [id])
  watchContextPersonId Int?
  recommender          Person?      @relation("Recommender", fields: [recommenderId], references: [id])
  recommenderId        Int?
  startedAt      DateTime?
  completedAt    DateTime?
  verified       Boolean      @default(false) // TODO[TEMP]: remove after data review
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([animeId, userId])
}
