generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  accounts      Account[]
  franchises    Franchise[]
  links         Link[]
  people        Person[]
  sessions      Session[]
  userEntries   UserEntry[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Person {
  id                  Int         @id @default(autoincrement())
  name                String
  userId              String
  createdAt           DateTime    @default(now())
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries             UserEntry[] @relation("Recommender")
  watchContextEntries UserEntry[] @relation("WatchContextPerson")

  @@unique([name, userId])
}

model Franchise {
  id          Int              @id @default(autoincrement())
  name        String
  userId      String
  description String?
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     FranchiseEntry[]

  @@unique([name, userId])
}

model FranchiseEntry {
  id          Int                @id @default(autoincrement())
  franchiseId Int
  animeId     Int
  order       Int
  entryType   FranchiseEntryType @default(MAIN)
  anime       Anime              @relation(fields: [animeId], references: [id], onDelete: Cascade)
  franchise   Franchise          @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, animeId])
  @@unique([franchiseId, order])
  @@index([franchiseId, order])
}

model Studio {
  id              Int           @id @default(autoincrement())
  name            String        @unique
  anilistStudioId Int?          @unique
  animeStudios    AnimeStudio[]
}

model AnimeStudio {
  animeId      Int
  studioId     Int
  isMainStudio Boolean @default(false)
  anime        Anime   @relation(fields: [animeId], references: [id], onDelete: Cascade)
  studio       Studio  @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@id([animeId, studioId])
}

model Anime {
  id                 Int              @id @default(autoincrement())
  anilistId          Int?             @unique
  source             AnimeSource      @default(ANILIST)
  titleEnglish       String?
  titleRomaji        String
  titleNative        String?
  coverImageUrl      String?
  synopsis           String?
  // JSON array of strings e.g. ["Action", "Drama"]
  genres             String           @default("[]")
  totalEpisodes      Int?
  totalSeasons       Int?
  // JSON array of ints e.g. [12, 13, 11] — one entry per season
  episodesPerSeason  String?
  durationMins       Int?
  airingStatus       AiringStatus     @default(FINISHED)
  displayFormat      DisplayFormat    @default(SERIES)
  sourceMaterial     SourceMaterial?
  season             Season?
  seasonYear         Int?
  meanScore          Int?
  nextAiringEp       Int?
  nextAiringAt       DateTime?
  lastKnownAiredEp   Int?
  lastSyncedAt       DateTime?
  tmdbId             Int?
  tmdbMediaType      String?
  externalUrl        String?
  streamingCheckedAt DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  startDay           Int?
  startMonth         Int?
  startYear          Int?
  animeStudios       AnimeStudio[]
  franchiseEntries   FranchiseEntry[]
  linkedIn           LinkedAnime[]
  streamingLinks     StreamingLink[]

  @@index([airingStatus])
}

model Link {
  id          Int           @id @default(autoincrement())
  name        String?
  userId      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedAnime LinkedAnime[]
  userEntry   UserEntry?

  @@index([userId])
}

model LinkedAnime {
  id      Int   @id @default(autoincrement())
  linkId  Int
  animeId Int
  order   Int   @default(0)
  anime   Anime @relation(fields: [animeId], references: [id])
  link    Link  @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@unique([linkId, animeId])
  @@index([linkId, order])
}

model StreamingLink {
  id      Int              @id @default(autoincrement())
  animeId Int
  service StreamingService
  url     String
  anime   Anime            @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([animeId, service])
}

model UserEntry {
  id                   Int            @id @default(autoincrement())
  userId               String
  watchStatus          WatchStatus    @default(PLAN_TO_WATCH)
  currentEpisode       Int            @default(0)
  score                Float?
  notes                String?
  watchContextPersonId Int?
  recommenderId        Int?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  discoverySource      String?
  discoveryType        DiscoveryType?
  linkId               Int?           @unique
  link                 Link?          @relation(fields: [linkId], references: [id], onDelete: Cascade)
  recommender          Person?        @relation("Recommender", fields: [recommenderId], references: [id])
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchContextPerson   Person?        @relation("WatchContextPerson", fields: [watchContextPersonId], references: [id])

  @@index([linkId])
}

enum AnimeSource {
  ANILIST
  MANUAL
}

enum AiringStatus {
  FINISHED
  RELEASING
  HIATUS
  CANCELLED
  NOT_YET_RELEASED
}

enum DisplayFormat {
  SERIES
  MOVIE
}

enum SourceMaterial {
  ORIGINAL
  MANGA
  LIGHT_NOVEL
  NOVEL
  VISUAL_NOVEL
  VIDEO_GAME
  OTHER
}

enum Season {
  WINTER
  SPRING
  SUMMER
  FALL
}

enum FranchiseEntryType {
  MAIN
  SIDE_STORY
  MOVIE
  OVA
}

enum WatchStatus {
  WATCHING
  COMPLETED
  DROPPED
  PLAN_TO_WATCH
  NOT_INTERESTED
}

enum StreamingService {
  NETFLIX
  HULU
  DISNEY_PLUS
  HBO
  CRUNCHYROLL
  AMAZON_PRIME
  HIDIVE
}

enum DiscoveryType {
  PERSONAL
  PLATFORM
  OTHER
  UNKNOWN
}
